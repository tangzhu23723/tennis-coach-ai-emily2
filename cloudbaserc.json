{
  "envId": "tangzhu-d5g3fxav4f47f5237",
  "version": "2.0",
  "$comment": "腾讯云 CloudBase - 仅用于静态网站托管（前端）",
  "framework": {
    "name": "tennis-coach-ai",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "outputPath": "tennis-coach-ai/dist",
          "cloudPath": "/",
          "ignore": [
            "node_modules",
            ".git",
            "backend",
            ".github",
            "SPEC.md"
          ]
        }
      }
    }
  }
}
