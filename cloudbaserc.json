{
  "envId": "tangzhu-d5g3fxav4f47f5237",
  "version": "2.0",
  "$comments": "腾讯云 CloudBase 配置文件",
  "functions": [
    {
      "name": "tennis-coach-backend",
      "path": "backend/dist",
      "timeout": 60,
      "envVariables": {
        "DEEPSEEK_API_KEY": "sk-4e7786dcf6f740bda5cbfdad703f9635",
        "NODE_ENV": "production"
      },
      "runtime": "Nodejs18.15",
      "memorySize": 512,
      "installDeps": true,
      "handler": "index.main"
    }
  ],
  "framework": {
    "name": "tennis-coach-ai",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-website",
        "inputs": {
          "outputPath": "tennis-coach-ai/dist",
          "cloudPath": "/"
        }
      },
      "server": {
        "use": "@cloudbase/framework-plugin-node",
        "inputs": {
          "name": "tennis-coach-backend",
          "path": "backend",
          "buildCommand": "npm run build",
          "command": "npm run start"
        }
      }
    }
  }
}
